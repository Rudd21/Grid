// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  email String @unique
  name String
  password String

  skills String[]
  experienceLevel ExperienceLevel @default(JUNIOR)

  membership Member[]
  tasks Task[]
  comment Comment[]

  receivedNotifications Notification[] @relation("received")
  sentNotifications Notification[] @relation("sent")
}

enum ExperienceLevel {
  JUNIOR
  MIDDLE
  SENIOR
}

model Project {
  id String @id @default(uuid())
  title String
  description String
  isPublic Boolean @default(true)

  status ProjectStatus
  members Member[]
  sprints Sprint[]
  tasks Task[]
  notification Notification[]
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  CLOSED
}

model Member {
  id String @id @default(uuid())
  role UserRole

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

enum UserRole {
  OWNER
  MANAGER
  MEMBER
}

model Sprint {
  id String @id @default(uuid())
  title String
  start_date DateTime
  end_date DateTime

  project Project @relation(fields: [id_project], references: [id])
  id_project String
  tasks Task[]
}

model Task {
  id String @id @default(uuid())
  title String
  description String?
  difficulty TaskDifficulty @default(MEDIUM)
  taken_at DateTime?
  
  tags String[]
  commit String?
  commit_description String?
  done_at DateTime?
  status TaskStatus @default(TODO)

  notification Notification[]
  comment Comment[]

  user User? @relation(fields: [id_user], references: [id])
  id_user String?

  sprint Sprint @relation(fields: [id_sprint], references: [id])
  id_sprint String

  project Project @relation(fields: [id_project], references: [id])
  id_project String
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

enum TaskStatus {
  TODO
  DOING
  DONE
}

model Notification {
  id String @id @default(uuid())
  type NotificationType
  message String
  isRead Boolean @default(false)
  created_at DateTime @default(now())

  receiver User @relation("received", fields: [id_receiver], references: [id])
  id_receiver String

  sender User @relation("sent", fields: [id_sender], references: [id])
  id_sender String

  task Task? @relation(fields: [id_task], references: [id])
  id_task String?

  project Project? @relation(fields: [id_project], references: [id])
  id_project String?
}

enum NotificationType {
  TASK_RECOMMEND
  TASK_TRANSFER  
}

model Comment {
  id String @id @default(uuid())
  text String

  task Task @relation(fields: [id_task], references: [id])
  id_task String

  user User @relation(fields: [id_user], references: [id])
  id_user String
}